# ══════════════════════════════════════════════════════
# BOT-AUTO-TRADE-KRAKEN – Environment Configuration
# ══════════════════════════════════════════════════════
#
# Only INFRASTRUCTURE settings go here.
# All trading settings (Kraken API, risk, autopilot,
# Telegram) are configured from the dashboard UI
# and stored encrypted in the database.
#
# ── Database (TimescaleDB) ─────────────────────────────
DB_HOST=timescaledb
DB_PORT=5432
DB_NAME=trading_kraken
DB_USER=trader
DB_PASSWORD=change_me_in_production

# ── Redis ──────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Dashboard ──────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
DASHBOARD_SECRET_KEY=change_me_random_secret_key_min_32_chars
DASHBOARD_ADMIN_USER=admin
DASHBOARD_ADMIN_PASSWORD=change_me_strong_password

# ── HTTPS / SSL ────────────────────────────────────────
# Domain name for Let's Encrypt certificate
DOMAIN=bot.example.com
CERT_EMAIL=admin@example.com

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=INFO
